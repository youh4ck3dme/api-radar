# .env template for API Centrum
# Kopírujte tento súbor ako .env a vyplňte reálne hodnoty

# Websupport Standard API key (DNS záznamy, FTP účty)
# Nájdete v: admin.websupport.sk → API Management → Štandardný API kľúč
WEBSUPPORT_API_KEY=vaš_identifikator_uuid
WEBSUPPORT_SECRET=vaš_tajny_kluc_sha1

# Websupport DynDNS API key (pre DynDNS aktualizácie)
# Nájdete v: admin.websupport.sk → API Management → DynDNS API kľúč
WEBSUPPORT_DYNDNS_KEY=vaš_dyndns_identifikator_uuid
WEBSUPPORT_DYNDNS_SECRET=vaš_dyndns_tajny_kluc

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Databáza (Vývoj: sqlite:///./test.db)
# Aplikácia beží na porte 5555 (hlavný) a 5556 (sekundárny).
DATABASE_URL=sqlite:///./test.db

# Certifikáty
CERTBOT_EMAIL=larsenevans@proton.me

# Nastavenia aplikácie
ENV=development
JWT_SECRET=generujte_nahodny_dlhy_string_aspon_32_znakov
JWT_EXPIRE_MINUTES=1440

# Bezpečnosť (Produkcia)
ALLOWED_HOSTS=localhost,127.0.0.1,vaša_doména.sk,testserver
CORS_ORIGINS=http://localhost:3000,https://vaša_doména.sk
